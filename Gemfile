source "https://rubygems.org"

# Use Jekyll 4.x which is much more compatible with Ruby 4.0+
gem "jekyll", "~> 4.3.3"

# Use a Liquid version that removes the "tainted?" error found in Ruby 3.2/4.0
gem "liquid", "~> 4.0.4"

# Required for Ruby 3.4 / 4.0+ because they are no longer in the standard library
gem "base64"
gem "logger"
gem "mutex_m"

# Required for local preview in Ruby 3.0+
gem "webrick"
gem "csv"
gem "bigdecimal"

# Plugins you were likely using via github-pages
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end